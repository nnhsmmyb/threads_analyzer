# Threads API（Meta Developer Console > Threads use case）
THREADS_APP_ID=
THREADS_APP_SECRET=
# Meta Settings の Redirect Callback URL と完全一致（HTTPS localhost 推奨）
THREADS_OAUTH_REDIRECT_URI=https://127.0.0.1:8080/callback
THREADS_API_BASE=https://graph.threads.net

# python3 threads_oauth_setup.py --manual 実行後に自動で書き込まれる
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_TOKEN_OBTAINED_AT=
THREADS_TOKEN_EXPIRES_AT=
